<!-- cadastra vinho -->

<%= form_with(model: wine, class: "shadow p-4 rounded bg-light") do |form| %>
  <% if wine.errors.any? %>
    <div class="alert alert-danger">
      <h4 class="alert-heading"><%= pluralize(wine.errors.count, "erro") %> impediram a gravação:</h4>
      <ul class="mb-0">
        <% wine.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, "Nome do Vinho", class: "form-label fw-bold" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Ex: Pêra-Manca 2014" %>
  </div>

  <div class="mb-3">
    <%= form.label :description, "Descrição / Notas de Prova", class: "form-label fw-bold" %>
    <%= form.text_area :description, class: "form-control", rows: 3 %>
  </div>

  <div class="row">
  <div class="col-md-6 mb-3">
    <%= form.label :rating, "Avaliação (1 a 5 ⭐)", class: "form-label fw-bold" %>
    <%= form.number_field :rating, class: "form-control", min: 1, max: 5 %>
  </div>

  <div class="col-md-6 mb-3">
    <%# Campo de Texto no lugar do Select %>
    <%= form.label :local, "Local / Origem", class: "form-label fw-bold" %>
    <%= form.text_field :local, class: "form-control", placeholder: "Ex: Mendoza, Chile, etc." %>
  </div>
</div>

  <div class="mb-3">
    <%= form.label :photo, "Foto da Garrafa", class: "form-label fw-bold" %>
    <%= form.file_field :photo, class: "form-control" %>
  </div>

  <div class="mb-4">
    <label class="form-label fw-bold d-block">Características (Tags)</label>
    <div class="d-flex flex-wrap gap-3 p-2 border rounded bg-white">
      <%= form.collection_check_boxes :tag_ids, Tag.all, :id, :name do |b| %>
        <div class="form-check">
          <%= b.check_box(class: "form-check-input") %>
          <%= b.label(class: "form-check-label") %>
        </div>
      <% end %>
    </div>
  </div>

  <div class="d-grid">
    <%= form.submit "Salvar Vinho no Winelog", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>