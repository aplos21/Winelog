<!DOCTYPE html>
<html>
  <head>
    <title>Winelog</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  </head>

  <body>

    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container">
        <%= link_to root_path, class: "navbar-brand fw-bold d-flex align-items-center" do %>
          <%= image_tag "emblema_confraria.png", class: "nav-logo-custom", alt: "Logo" %>
          Confraria Grau 33
        <% end %>
        
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="navbarNav">
          <% if user_signed_in? %>
            <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-2 mt-2 mt-lg-0">
              <li class="nav-item">
                <%= link_to "Minhas Postagens", wines_path, class: "btn btn-outline-light btn-sm w-100 text-start text-lg-center" %>
              </li>
              <li class="nav-item">
                <%= link_to "Comunidade", feed_path, class: "btn btn-outline-light btn-sm w-100 text-start text-lg-center" %>
              </li>
            </ul>

            <ul class="navbar-nav ms-auto align-items-lg-center gap-2">
              <li class="nav-item">
                <span class="text-light small">Olá, <%= current_user.email.split('@').first %></span>
              </li>

              <li class="nav-item nav-item-mobile-inline">
                <%= link_to edit_user_registration_path, class: "nav-link p-0 d-inline-flex align-items-center" do %>
                  <% if current_user.photo.attached? %>
                    <%= image_tag current_user.photo, class: "rounded-circle border border-secondary", style: "width: 32px; height: 32px; object-fit: cover;" %>
                  <% else %>
                    <i class="bi bi-gear-fill text-light" style="font-size: 1.2rem;" title="Configurações"></i>
                  <% end %>
                <% end %>
              </li>

              <li class="nav-item mt-2 mt-lg-0">
                <%= link_to "Sair", destroy_user_session_path, data: { "turbo-method": :delete }, class: "nav-link text-danger p-0 fw-bold d-inline-block" %>
              </li>
            </ul>
          <% end %>
        </div>
      </div>
    </nav>

    <main class="container-fluid px-2 px-sm-3">
      <div class="main-content-area">
        <%= yield %>
      </div>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>