

<div class="container-fluid vh-100 d-flex align-items-center">
  <div class="row w-100 align-items-center">
    
    <div class="col-md-6 col-lg-7 d-none d-md-flex justify-content-end pe-5">
      <div class="texto-boas-vindas" style="max-width: 500px;">
        <h1>Confraria Grau 33</h1>
        <p>Recupere seu acesso para voltar aos brindes.</p>
      </div>
    </div>

    <div class="col-md-5 col-lg-4 col-xl-3">
      <div class="card shadow-lg border-0 p-4 rounded-4 login-glass">
        <div class="mb-4 text-center">
          <%= image_tag "emblema_confraria.png", style: "height: 80px;" %>
          <h2 class="fw-bold text-dark mt-2 mb-0">Forgot your password?</h2>
        </div>

        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
          <div class="mb-3">
            <%= f.label :email, class: "form-label fw-bold small text-dark" %>
            <%= f.email_field :email, autofocus: true, class: "form-control shadow-sm border-0 bg-white-50 py-2" %>
          </div>

          <div class="d-grid mt-4">
            <%= f.submit "Send instructions", class: "btn btn-dark fw-bold py-2 shadow-sm" %>
          </div>
        <% end %>

        <div class="mt-4 pt-3 border-top border-secondary text-center">
          <%= render "devise/shared/links" %>
        </div>
      </div>
    </div>
  </div>
</div>